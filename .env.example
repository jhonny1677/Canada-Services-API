# Server Configuration
PORT=3000
NODE_ENV=development
# Full public URL of this server — used as the base URL in Swagger UI and /docs.json
SERVER_URL=http://localhost:3000

# Caching Settings (in seconds)
CACHE_TTL_SECONDS=3600
GEOCODE_CACHE_TTL_SECONDS=86400

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
# Stricter limit for geocode endpoints — they proxy the external Nominatim API and
# hammering them risks getting the server's IP blocked by the upstream service.
RATE_LIMIT_GEOCODE_MAX_REQUESTS=30

# API Endpoints (optional custom endpoints)
NOMINATIM_URL=https://nominatim.openstreetmap.org
OVERPASS_URL=https://overpass-api.de/api

# Logging
LOG_LEVEL=info
LOG_FILE=logs/api.log

# CORS Settings
CORS_ORIGIN=*
CORS_METHODS=GET,POST,PUT,DELETE
CORS_HEADERS=Content-Type,Authorization

# PostgreSQL / PostGIS (used by docker-compose and the app's db layer)
POSTGRES_USER=canada_user
POSTGRES_PASSWORD=canada_pass
POSTGRES_DB=canada_services
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://canada_user:canada_pass@localhost:5432/canada_services